SEEDANCE_API_KEY=your_api_key_here

# Default model or endpoint ID used when no model is provided.
SEEDANCE_MODEL=doubao-seedance-2-0-260128

# Comma-separated model candidates shown in the GUI.
# Model families covered:
# - Seedance 2.0: multimodal reference/video generation, audio supported
# - Seedance 2.0 Fast: faster/cost-oriented Seedance 2.0 variant
# - Seedance 1.5 Pro: text/image-to-video, audio and draft mode supported
# - Seedance 1.0 Pro: text/image-to-video
# - Seedance 1.0 Pro Fast: text-to-video and first-frame image-to-video
# - Seedance 1.0 Lite T2V: text-to-video
# - Seedance 1.0 Lite I2V: image-to-video/reference-image mode
